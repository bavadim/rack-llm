{
  "experiment": "paper-full",
  "provider": "llama-local",
  "provider_mode": "exact-full-vocab",
  "model_env": "RACK_LLM_MODEL",
  "budgets": [1, 2, 4, 8, 16],
  "seed": 42,
  "split_ratios": {
    "calibration": 0.34,
    "dev": 0.33,
    "test": 0.33
  },
  "prompt_template": "weak-ifbench-local-candidate",
  "grammar": "weak-ifbench-constraints",
  "weak_rules": [
    "word-count/split",
    "word-count/regex",
    "sentence-count/punctuation",
    "sentence-count/newline",
    "phrase-presence/lowercase",
    "phrase-presence/raw",
    "forbidden-phrase/lowercase",
    "forbidden-phrase/word-boundary",
    "format/header-prefix",
    "format/markdown-headings",
    "json/parse",
    "json/braces",
    "markdown/headings",
    "markdown/list-or-code"
  ],
  "outputs": {
    "run_dir": "runs/paper-full",
    "metrics": "runs/paper-full/metrics.csv",
    "traces": "runs/paper-full/traces.jsonl",
    "tables": "runs/paper-full/tables"
  }
}
